# Local testing with @github/local-action
# Copy to .env and fill in real values
#
# Usage: npx @github/local-action . src/main.ts .env

# Action inputs (required)
INPUT_BACKEND-URL=http://localhost:8080
INPUT_API-KEY=your-base64-encoded-key
INPUT_GITHUB-TOKEN=ghp_your_token

# Action inputs (optional)
INPUT_TIMEOUT-SECONDS=300
INPUT_UPLOAD-ARTIFACT=false

# GitHub context
GITHUB_REPOSITORY=owner/repo

# --- Test scenarios ---
# Uncomment ONE event block below. Default: PR opened.

# 1. PR opened (full review)
#    Triggers handlePullRequest: fetches all changed files, sends to backend,
#    posts inline review comments.
GITHUB_EVENT_NAME=pull_request
GITHUB_EVENT_PATH=__fixtures__/pull_request.opened.json

# 2. PR synchronize (new push to existing PR)
#    Currently skipped (not supported). Tests that the action exits early.
#GITHUB_EVENT_NAME=pull_request
#GITHUB_EVENT_PATH=__fixtures__/pull_request.synchronize.json

# 3. Human replies to a bot review comment (reply flow)
#    Triggers handleReviewComment: fetches thread + file context, sends to
#    backend, posts threaded reply. The comment is from a human replying to
#    a bot-initiated thread (in_reply_to_id points to the root comment).
#GITHUB_EVENT_NAME=pull_request_review_comment
#GITHUB_EVENT_PATH=__fixtures__/review_comment.created.json

# 4. Bot comment (loop prevention, should skip)
#    Same event type as #3 but the comment author is github-actions[bot]
#    and body contains the comment marker. shouldSkipComment returns
#    'bot_author' and the action exits early with no backend call.
#GITHUB_EVENT_NAME=pull_request_review_comment
#GITHUB_EVENT_PATH=__fixtures__/review_comment.bot.json
